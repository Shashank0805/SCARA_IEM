        RowBox[{"expression", "=", 
         RowBox[{"Simplify", "[", 
          RowBox[{"Numerator", "[", 
           RowBox[{"Together", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
