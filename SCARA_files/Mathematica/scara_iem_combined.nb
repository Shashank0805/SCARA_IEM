Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Computed", " ", "Torque", " ", "Control"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Kp1", "=", 
     RowBox[{"15000", "*", 
      RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Kv1", "=", 
     RowBox[{"2", "*", 
      RowBox[{"Sqrt", "[", "Kp1", "]"}], "*", 
      RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Theta]des1", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Theta]1", ",", "\[Theta]2", ",", "0.3"}], "}"}], "/.", 
      "iktrj"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"err1", "=", 
     RowBox[{"\[Theta]des1", "-", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Theta]1", "[", "t", "]"}], ",", 
        RowBox[{"\[Theta]2", "[", "t", "]"}], ",", 
        RowBox[{"d3", "[", "t", "]"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Theta]dotdes1", "=", 
     RowBox[{"D", "[", 
      RowBox[{"\[Theta]des1", ",", "t"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Theta]ddotdes1", " ", "=", 
     RowBox[{"D", "[", 
      RowBox[{"\[Theta]dotdes1", ",", "t"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errdot1", "=", 
     RowBox[{"\[Theta]dotdes1", "-", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]1", "'"}], "[", "t", "]"}], ",", 
        RowBox[{
         RowBox[{"\[Theta]2", "'"}], "[", "t", "]"}], ",", 
        RowBox[{
         RowBox[{"d3", "'"}], "[", "t", "]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]ctau", "=", 
     RowBox[{
      RowBox[{"MM", ".", "\[Theta]ddotdes1"}], "+", 
      RowBox[{"Cor", ".", "dq"}], "+", "G", "+", 
      RowBox[{"Kp1", ".", "err1"}], "+", 
      RowBox[{"Kv1", ".", "errdot1"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Tau]c", "=", 
     RowBox[{
      RowBox[{"Kp", ".", "err"}], "+", 
      RowBox[{"Kv", ".", "errdot"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"s2", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"eqdyn1", ",", "eqdyn2", ",", "eqdyn3"}], "}"}], "==", 
          "\[Tau]ctau"}], ",", 
         RowBox[{
          RowBox[{"\[Theta]1", "[", "0", "]"}], "==", 
          RowBox[{"\[Pi]", "/", "4"}]}], ",", 
         RowBox[{
          RowBox[{"\[Theta]2", "[", "0", "]"}], "==", 
          RowBox[{"\[Pi]", "/", "6"}]}], ",", 
         RowBox[{
          RowBox[{"d3", "[", "0", "]"}], "==", "0.1"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Theta]1", "'"}], "[", "0", "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Theta]2", "'"}], "[", "0", "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"d3", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]1", ",", "\[Theta]2", ",", "d3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "TF"}], "}"}], ",", 
       RowBox[{"Method", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<EquationSimplification\>\"", "->", "\"\<Residual\>\""}],
          "}"}]}]}], "]"}]}], ";"}], "\n", 
